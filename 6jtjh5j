import React, { useState, useEffect, useRef } from 'react';
import { base44 } from '@/api/base44Client';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { Send, Loader2, ShieldAlert, ShieldCheck } from 'lucide-react';
import { usePullToRefresh } from '@/hooks/usePullToRefresh';
import PullToRefreshIndicator from '@/components/shared/PullToRefreshIndicator';
import { Button } from '@/components/ui/button';
import { Textarea } from '@/components/ui/textarea';
import { Badge } from '@/components/ui/badge';
import { motion, AnimatePresence } from 'framer-motion';
import { format } from 'date-fns';
import { nl } from 'date-fns/locale';
import { cn } from '@/lib/utils';

async function checkTone(text) {
  const res = await base44.integrations.Core.InvokeLLM({
    prompt: `Beoordeel de toon van dit bericht van een ouder naar een andere ouder. 
Is het agressief, beledigend, of erg negatief? Antwoord ALLEEN met JSON.

Bericht: "${text}"`,
    response_json_schema: {
      type: "object",
      properties: {
        flag: { type: "string", enum: ["neutral", "warning", "blocked"] },
        reason: { type: "string" }
      }
    }
  });
  return res;
}

export default function Chat() {
  const queryClient = useQueryClient();
  const [input, setInput] = useState('');
  const [checking, setChecking] = useState(false);
  const [toneResult, setToneResult] = useState(null);
  const [user, setUser] = useState(null);
  const bottomRef = useRef(null);

  useEffect(() => {
    base44.auth.me().then(setUser).catch(() => {});
  }, []);

  const { data: messages = [] } = useQuery({
    queryKey: ['messages'],
    queryFn: () => base44.entities.Message.list('created_date', 100),
    refetchInterval: 5000,
  });

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [messages]);

  const sendMessage = useMutation({
    mutationFn: (data) => base44.entities.Message.create(data),
    onMutate: async (data) => {
      await queryClient.cancelQueries({ queryKey: ['messages'] });
      const prev = queryClient.getQueryData(['messages']);
      queryClient.setQueryData(['messages'], (old = []) => [
        ...old,
        { ...data, id: `temp-${Date.now()}`, created_date: new Date().toISOString() },
      ]);
      return { prev };
    },
    onError: (_err, _data, ctx) => {
      if (ctx?.prev) queryClient.setQueryData(['messages'], ctx.prev);
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['messages'] });
      setInput('');
      setToneResult(null);
    },
  });

  const handleSend = async () => {
    const text = input.trim();
    if (!text) return;

    setChecking(true);
    const tone = await checkTone(text);
    setChecking(false);

    if (tone.flag === 'blocked') {
      setToneResult(tone);
      return;
    }

    sendMessage.mutate({
      content: text,
      sender_email: user?.email || 'unknown',
      sender_name: user?.full_name || user?.email || 'Ouder',
      tone_flag: tone.flag,
      tone_reason: tone.reason,
    });
    setToneResult(null);
  };

  const handleKeyDown = (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  };

  const isOwnMessage = (msg) => msg.sender_email === user?.email;

  const scrollRef = useRef(null);
  const { pullY } = usePullToRefresh({
    onRefresh: () => queryClient.invalidateQueries({ queryKey: ['messages'] }),
    containerRef: scrollRef,
  });

  return (
    <div className="flex flex-col h-[calc(100vh-7rem)] md:h-[calc(100vh-4rem)]">
      <PullToRefreshIndicator pullY={pullY} />
      <div className="mb-4">
        <h1 className="font-heading text-2xl font-semibold">Chat</h1>
        <p className="text-sm text-muted-foreground flex items-center gap-1.5 mt-0.5">
          <ShieldCheck className="w-3.5 h-3.5 text-primary" />
          Tone Guard actief — agressieve berichten worden geblokkeerd
        </p>
      </div>

      <div ref={scrollRef} className="flex-1 overflow-y-auto space-y-3 pb-2">
        {messages.length === 0 && (
          <div className="text-center py-12 text-muted-foreground text-sm">
            Nog geen berichten. Stuur het eerste bericht!
          </div>
        )}
        <AnimatePresence initial={false}>
          {messages.map((msg) => {
            const own = isOwnMessage(msg);
            return (
              <motion.div
                key={msg.id}
                initial={{ opacity: 0, y: 6 }}
                animate={{ opacity: 1, y: 0 }}
                className={cn('flex gap-2', own ? 'justify-end' : 'justify-start')}
              >
                <div className={cn('max-w-[75%]', own && 'items-end flex flex-col')}>
                  {!own && (
                    <p className="text-xs text-muted-foreground mb-1 ml-1">{msg.sender_name || msg.sender_email}</p>
                  )}
                  <div className={cn(
                    'px-4 py-2.5 rounded-2xl text-sm',
                    own ? 'bg-primary text-primary-foreground rounded-br-sm' : 'bg-card border border-border rounded-bl-sm'
                  )}>
                    {msg.content}
                  </div>
                  <div className="flex items-center gap-1.5 mt-1 px-1">
                    <span className="text-xs text-muted-foreground">
                      {format(new Date(msg.created_date), 'HH:mm', { locale: nl })}
                    </span>
                    {msg.tone_flag === 'warning' && (
                      <Badge variant="outline" className="text-xs py-0 h-4 border-orange-200 text-orange-600 bg-orange-50">
                        ⚠️ waarschuwing
                      </Badge>
                    )}
                  </div>
                </div>
              </motion.div>
            );
          })}
        </AnimatePresence>
        <div ref={bottomRef} />
      </div>

      {toneResult?.flag === 'blocked' && (
        <div className="mb-3 p-3 rounded-lg bg-red-50 border border-red-200 flex items-start gap-2 text-sm">
          <ShieldAlert className="w-4 h-4 text-red-500 mt-0.5 shrink-0" />
          <div>
            <p className="font-medium text-red-700">Bericht geblokkeerd door Tone Guard</p>
            <p className="text-red-600 mt-0.5">{toneResult.reason || 'Dit bericht is te agressief of beledigend.'}</p>
            <button className="text-red-500 underline text-xs mt-1" onClick={() => setToneResult(null)}>Bericht aanpassen</button>
          </div>
        </div>
      )}

      <div className="border-t border-border pt-3 mt-auto flex gap-2">
        <Textarea
          value={input}
          onChange={(e) => setInput(e.target.value)}
          onKeyDown={handleKeyDown}
          placeholder="Schrijf een bericht..."
          className="resize-none min-h-[2.5rem] max-h-28"
          rows={1}
        />
        <Button
          onClick={handleSend}
          disabled={!input.trim() || checking || sendMessage.isPending}
          size="icon"
          className="shrink-0"
        >
          {checking || sendMessage.isPending
            ? <Loader2 className="w-4 h-4 animate-spin" />
            : <Send className="w-4 h-4" />}
        </Button>
      </div>
    </div>
  );
}
